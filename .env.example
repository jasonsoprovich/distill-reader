# Postgres
POSTGRES_USER=distill
POSTGRES_PASSWORD=changeme
POSTGRES_DB=distill
# Host port postgres is published on (docker-compose.yml), so host-run tools
# (pnpm db:migrate, pnpm dev) can reach it. Change if 5432 is already taken
# locally. Containers on the compose network always address it as
# `postgres:5432` regardless of this value.
POSTGRES_PORT=5432
# Used by both containers (leave the `postgres` hostname as-is — it only
# resolves on the compose network) and, when running `pnpm db:migrate` /
# `pnpm dev` from the host, replace `postgres` with `localhost:${POSTGRES_PORT}`.
DATABASE_URL=postgresql://distill:changeme@postgres:5432/distill

# Better Auth (wired in Phase 1)
BETTER_AUTH_SECRET=changeme-32-byte-random-secret
BETTER_AUTH_URL=http://localhost:3001

# Origin(s) the API trusts for CORS + Better Auth's CSRF origin check.
# Comma-separated if the web app is reachable from more than one origin.
WEB_ORIGIN=http://localhost:3000

# Optional OAuth sign-in (GitHub/Google) — leave a pair unset to hide that
# provider's button entirely (GET /auth/social-providers, checked by the
# login/setup pages). Either can create the app's first account, or (once
# one exists) any further account allowlisted via ALLOWED_SIGNUP_EMAILS.
# Register an OAuth app with each provider using the callback URL
# {BETTER_AUTH_URL}/auth/callback/github (or /google), e.g.
# http://localhost:3001/auth/callback/github for local dev.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: create the initial account non-interactively via the "seed"
# compose service, for headless/automated deploys. Leave unset (the default)
# and the web app's first-run /setup page will prompt for these instead.
INITIAL_USER_EMAIL=
INITIAL_USER_PASSWORD=

# Optional Stripe billing — leave both STRIPE_SECRET_KEY and
# STRIPE_WEBHOOK_SECRET unset to keep the Stripe plugin (and its
# /auth/stripe/webhook route) disabled entirely, same pattern as the OAuth
# vars above. Set up a webhook in the Stripe dashboard pointing at
# {BETTER_AUTH_URL}/auth/stripe/webhook subscribed to
# checkout.session.completed, customer.subscription.created, .updated, and
# .deleted, then paste its signing secret below.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID (not product ID) for the single "pro" plan, from the Stripe dashboard.
STRIPE_PRO_PRICE_ID=

# Master switch for free-tier limits (feed count, AI features, BYOK API
# keys, non-basic themes — see apps/api/src/lib/entitlements.ts). Leave
# false/unset and every user gets full access regardless of subscription
# state, which is the correct default until pricing/tiers are finalized.
PAYWALL_ENABLED=false
INITIAL_USER_NAME=Admin

# Optional: once the first account exists, sign-up (email/password or OAuth)
# is closed to everyone except the addresses listed here (comma-separated,
# case-insensitive) — /signup and the backend's /auth/sign-up/email route
# both enforce this. Leave unset to keep the original single-user behavior
# (no further sign-ups, ever). Example: jane@example.com,alex@example.com
ALLOWED_SIGNUP_EMAILS=

# AEAD key for encrypting stored provider API keys (Phase 5). Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY=changeme-generate-with-openssl-rand-base64-32

# Audio narration storage (Phase 7)
AUDIO_STORAGE_PATH=/data/audio

# Optional local providers — leave unset to disable. ElevenLabs (cloud TTS)
# needs no env var here; its key is added via Settings like OpenAI/Anthropic
# and stored encrypted (api_credential), not passed through the environment.
OLLAMA_BASE_URL=
# Set to http://localhost:5001 to use the bundled sidecar
# (`docker compose --profile piper up`) with a host-run `pnpm dev`
# api/worker, or to http://piper:5000 if api/worker are also containerized
# (`docker compose up --build`). Or point at your own piper.http_server
# instance elsewhere. Host port defaults to 5001, not the container's
# native 5000 — macOS binds 5000 by default for AirPlay Receiver, so 5000
# silently fails to publish there.
PIPER_BASE_URL=
# Voice the bundled piper sidecar downloads/serves (docker/piper/Dockerfile)
# — a valid piper-voices model id, e.g. "en_US-lessac-medium". Unused if
# PIPER_BASE_URL points elsewhere.
PIPER_VOICE=en_US-lessac-medium
# Host port the piper sidecar publishes to (see PIPER_BASE_URL above).
# Change this if 5001 is also taken on your machine.
PIPER_PORT=5001
# Set to http://localhost:8880 to use the bundled sidecar
# (`docker compose --profile kokoro up`) with a host-run `pnpm dev`
# api/worker, or to http://kokoro:8880 if api/worker are also containerized.
# Or point at your own Kokoro-FastAPI instance elsewhere. Every built-in
# voice ships baked into the image, so unlike Piper there's no matching
# *_VOICE env var.
KOKORO_BASE_URL=
# Host port the kokoro sidecar publishes to (see KOKORO_BASE_URL above).
KOKORO_PORT=8880

# Local TTS relay agent (apps/relay-agent) — only needed when running THAT
# container, on a user's own machine, pointed at a cloud-hosted Distill
# instance. Not used by api/worker/web above. Irrelevant to local dev,
# where the api reaches piper/kokoro directly via their ports above instead.
# DISTILL_CLOUD_URL: the cloud instance's relay endpoint, e.g.
#   wss://your-instance.example.com/relay/agent
# DISTILL_RELAY_TOKEN: from that instance's Settings → Local TTS relay.
# Then set PIPER_BASE_URL / KOKORO_BASE_URL above to this machine's own
# sidecars (e.g. http://localhost:5001 / http://localhost:8880) so the
# agent knows what to expose.
DISTILL_CLOUD_URL=
DISTILL_RELAY_TOKEN=

# App URLs
API_PORT=3001
WEB_PORT=3000

# Baked into the web app's build (Vite exposes VITE_-prefixed vars to client code)
VITE_API_URL=http://localhost:3001

# Logging
LOG_LEVEL=info
NODE_ENV=development
