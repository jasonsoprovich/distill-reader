# Postgres
POSTGRES_USER=distill
POSTGRES_PASSWORD=changeme
POSTGRES_DB=distill
# Host port postgres is published on (docker-compose.yml), so host-run tools
# (pnpm db:migrate, pnpm dev) can reach it. Change if 5432 is already taken
# locally. Containers on the compose network always address it as
# `postgres:5432` regardless of this value.
POSTGRES_PORT=5432
# Used by both containers (leave the `postgres` hostname as-is — it only
# resolves on the compose network) and, when running `pnpm db:migrate` /
# `pnpm dev` from the host, replace `postgres` with `localhost:${POSTGRES_PORT}`.
DATABASE_URL=postgresql://distill:changeme@postgres:5432/distill

# Better Auth (wired in Phase 1)
BETTER_AUTH_SECRET=changeme-32-byte-random-secret
BETTER_AUTH_URL=http://localhost:3001

# Origin(s) the API trusts for CORS + Better Auth's CSRF origin check.
# Comma-separated if the web app is reachable from more than one origin.
WEB_ORIGIN=http://localhost:3000

# Optional: create the initial account non-interactively via the "seed"
# compose service, for headless/automated deploys. Leave unset (the default)
# and the web app's first-run /setup page will prompt for these instead —
# that page (and the backend's /auth/sign-up/email route) locks itself out
# permanently once one account exists, so this is never open registration.
INITIAL_USER_EMAIL=
INITIAL_USER_PASSWORD=
INITIAL_USER_NAME=Admin

# AEAD key for encrypting stored provider API keys (Phase 5). Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY=changeme-generate-with-openssl-rand-base64-32

# Audio narration storage (Phase 7)
AUDIO_STORAGE_PATH=/data/audio

# Optional local providers — leave unset to disable. ElevenLabs (cloud TTS)
# needs no env var here; its key is added via Settings like OpenAI/Anthropic
# and stored encrypted (api_credential), not passed through the environment.
OLLAMA_BASE_URL=
# Set to http://piper:5000 to use the bundled sidecar
# (`docker compose --profile piper up`), or point at your own
# piper.http_server instance elsewhere.
PIPER_BASE_URL=
# Voice the bundled piper sidecar downloads/serves (docker/piper/Dockerfile)
# — a valid piper-voices model id, e.g. "en_US-lessac-medium". Unused if
# PIPER_BASE_URL points elsewhere.
PIPER_VOICE=en_US-lessac-medium

# App URLs
API_PORT=3001
WEB_PORT=3000

# Baked into the web app's build (Vite exposes VITE_-prefixed vars to client code)
VITE_API_URL=http://localhost:3001

# Logging
LOG_LEVEL=info
NODE_ENV=development
