# Postgres
POSTGRES_USER=distill
POSTGRES_PASSWORD=changeme
POSTGRES_DB=distill
DATABASE_URL=postgresql://distill:changeme@postgres:5432/distill

# Better Auth (wired in Phase 1)
BETTER_AUTH_SECRET=changeme-32-byte-random-secret
BETTER_AUTH_URL=http://localhost:3001

# AEAD key for encrypting stored provider API keys (Phase 5). Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY=changeme-generate-with-openssl-rand-base64-32

# Audio narration storage (Phase 7)
AUDIO_STORAGE_PATH=/data/audio

# Optional local providers — leave unset to disable
OLLAMA_BASE_URL=
PIPER_BASE_URL=

# App URLs
API_PORT=3001
WEB_PORT=3000
PUBLIC_API_URL=http://localhost:3001

# Logging
LOG_LEVEL=info
NODE_ENV=development
