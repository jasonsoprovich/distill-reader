{
  "name": "distill-reader",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm --filter @distill/db --filter @distill/shared run build && pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "db:generate": "pnpm --filter @distill/db run generate",
    "db:migrate": "pnpm --filter @distill/db run migrate"
  }
}
