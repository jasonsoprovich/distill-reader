{
  "name": "@distill/providers",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tts/piper.js": {
      "types": "./dist/tts/piper.d.ts",
      "default": "./dist/tts/piper.js"
    },
    "./tts/kokoro.js": {
      "types": "./dist/tts/kokoro.d.ts",
      "default": "./dist/tts/kokoro.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@distill/db": "workspace:*",
    "@distill/extract": "workspace:*",
    "@distill/shared": "workspace:*",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
